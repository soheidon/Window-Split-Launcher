{
  "manifest_version": 3,
  "name": "Window Split Launcher",
  "version": "0.1.0",
  "description": "Open a configured URL next to your current Chrome window with one click.",
  "permissions": [
    "windows",
    "storage",
    "system.display"
  ],
  "action": {
    "default_title": "Open Window Split",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "background": {
    "service_worker": "background.js"
  },
  "options_page": "options.html"
}
